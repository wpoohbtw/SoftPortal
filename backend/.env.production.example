# Copy to /srv/SoftPortal/backend/.env and fill real values on the server.
# Do not commit the real .env file.

# Set before the first SoftPortal start. It is used only when the admin row is created.
PORTAL_ADMIN_PASSWORD=change-this-before-first-start

# For temporary HTTP-by-IP deployment keep this disabled.
# Change to 1 only after HTTPS is configured.
PORTAL_COOKIE_SECURE=0
PORTAL_COOKIE_SAMESITE=lax

# ProfitsNLosses backend is private and must listen only on 127.0.0.1.
PORTAL_PNL_API_URL=http://127.0.0.1:8001
PORTAL_PNL_WS_URL=ws://127.0.0.1:8001
PORTAL_PNL_DIST_PATH=/srv/ProfitsNLosses/dist

# FoldersNUsersParser backend is private and must listen only on 127.0.0.1.
PORTAL_FNUP_API_URL=http://127.0.0.1:8002
PORTAL_FNUP_DIST_PATH=/srv/FoldersNUsersParser/dist
